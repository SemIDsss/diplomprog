datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeliveryMethod {
  PICKUP
  CDEK
  BOXBERRY
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String?
  yandexId  String?    @unique
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  cartItems CartItem[]
  orders    Order[]
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(uuid())
  name       String
  categoryId String
  category   Category  @relation(
    fields: [categoryId],
    references: [id],
    onDelete: Cascade
  )
  products   Product[]

  @@unique([name, categoryId])
}

model Product {
  id            String           @id @default(uuid())
  title         String
  description   String
  price         Float
  imageUrl      String
  stock         Int              @default(0)
  status        ModerationStatus @default(PENDING)
  rejectReason  String?
  specs         Json             @default("{}")
  subcategoryId String
  subcategory   Subcategory      @relation(
    fields: [subcategoryId],
    references: [id]
  )
  createdAt     DateTime         @default(now())
  cartItems     CartItem[]
  orderItems    OrderItem[]
}

model CartItem {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(
    fields: [userId],
    references: [id],
    onDelete: Cascade
  )
  productId String
  product   Product @relation(
    fields: [productId],
    references: [id],
    onDelete: Cascade
  )
  quantity  Int     @default(1)

  @@unique([userId, productId])
}

model Order {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(
    fields: [userId],
    references: [id]
  )
  deliveryMethod DeliveryMethod @default(PICKUP)
  status         OrderStatus    @default(PENDING)
  totalPrice     Float
  createdAt      DateTime       @default(now())
  items          OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(
    fields: [orderId],
    references: [id],
    onDelete: Cascade
  )
  productId String
  product   Product @relation(
    fields: [productId],
    references: [id]
  )
  quantity  Int
  price     Float
}
