// ИСПРАВЛЕНО: Соответствует спецификации Prisma v7
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"  // 
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String?  // Опционально, так как для Яндекс ID пароль не нужен
  yandexId   String?  @unique @map("yandex_id")   // В коде пишем yandexId, в БД запишется yandex_id
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  phone      String?  @unique
  isVerified Boolean  @default(false) @map("is_verified") // Полная синхронизация флага верификации
  createdAt  DateTime @default(now()) @map("created_at")

  products   Product[]
  orders     Order[]

  @@map("users") // Переименование таблицы в БД в нижний регистр
}


model Product {
  id              Int         @id @default(autoincrement())
  oneCId            String?     @unique
  name              String
  description       String?
  price           Float
  stock           Int         @default(0)
  image           String?
  category        String
  status          String      @default("PENDING_MODERATION")
  sellerId        Int? 
  seller            User?       @relation(fields: [sellerId], references: [id]) 
  reviews           Review[]
  orderItems        OrderItem[] 
  sku             String?     @unique
  barcode           String?
  brand           String?
  weightGrams     Int         @default(0)
  widthMm         Int         @default(0)
  heightMm        Int         @default(0)
  lengthMm        Int         @default(0)
  metadata        Json?       
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  status          String      @default("pending")
  totalPrice      Float
  cdekTariffId    Int?
  cdekDispatchId  String?
  yandexInvoiceId String?
  createdAt       DateTime    @default(now())
  items           OrderItem[] 
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int      @default(1)
  priceAtPurchase Float    
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int      
  userName  String
  rating    Int
  comment   String
  metadata  Json?    
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}
