datasource db {
  provider = "postgresql" // или используемый вами провайдер (например, mysql, sqlite)
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeliveryMethod {
  PICKUP
  CDEK
  BOXBERRY
}

enum OrderStatus {
  PENDING // Ожидает подтверждения
  PROCESSING // В сборке
  SHIPPED // Отправлен
  DELIVERED // Доставлен
  CANCELLED // Отменен
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String? // Необязательно, так как будет Яндекс-ID
  yandexId  String?  @unique // Для авторизации продавцов/пользователей через Яндекс
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  products  Product[]  @relation("SellerProducts") // Товары, добавленные этим продавцом
  cartItems CartItem[]
  orders    Order[]
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique // "Книги", "Мебель", "Игрушки"
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(uuid())
  name       String // "Манга", "Кухня", "Для собак"
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([name, categoryId])
}

model Product {
  id            String           @id @default(uuid())
  title         String
  description   String
  price         Float
  imageUrl      String
  stock         Int              @default(0) // Наличие товара у продавца
  status        ModerationStatus @default(PENDING)
  sellerId      String
  seller        User             @relation("SellerProducts", fields: [sellerId], references: [id])
  subcategoryId String
  subcategory   Subcategory      @relation(fields: [subcategoryId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model CartItem {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([userId, productId])
}

model Order {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  deliveryMethod DeliveryMethod @default(PICKUP)
  status         OrderStatus    @default(PENDING)
  totalPrice     Float
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float // Фиксация цены на момент покупки
}

// Таблица экстремистских материалов для проверки администратором
model ExtremistBook {
  id        String   @id @default(uuid())
  title     String   @unique
  createdAt DateTime @default(now())
}
